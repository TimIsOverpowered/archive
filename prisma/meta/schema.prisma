generator meta_client {
  provider = "prisma-client-js"
  output   = "../generated/meta"
}

datasource db {
  provider = "postgresql"
  url      = env("META_DATABASE_URL")
}

model Tenant {
  id        String   @id // e.g., "xqc", "shroud"
  name      String
  platform  String[] // ["twitch"], ["youtube"], or both
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  credentials Credential[]
  
  @@map("tenants")
}

model Credential {
  id             String   @id @default(uuid())
  tenantId       String
  platform       String // "twitch", "youtube", "kick", or "database"
  type           String // "client_id", "client_secret", "refresh_token", "db_url", etc.
  encryptedValue Bytes? // AES-256-GCM ciphertext
  iv             Bytes?   // Initialization vector for decryption
  
  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([tenantId, platform, type])
  @@map("credentials")
}

model Admin {
  id          String   @id @default(uuid())
  apiKeyHash  String   @unique // bcrypt hash of raw API key (never store plaintext!)
  createdAt   DateTime @default(now())
  
  @@map("admins")
}
