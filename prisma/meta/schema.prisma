generator meta_client {
  provider = "prisma-client-js"
  output   = "../generated/meta"
}

datasource db {
  provider = "postgresql"
  url      = env("META_DATABASE_URL")
}

model Tenant {
  id            Int      @id @default(autoincrement())
  display_name  String?
  twitch        Json?
  youtube       Json?
  kick          Json?
  google        Json?
  database_url  String? // encrypted connection string
  settings      Json
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("tenants")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  api_key      String   @unique
  api_key_hash String   @unique
  created_at   DateTime @default(now())

  @@map("admins")
}
