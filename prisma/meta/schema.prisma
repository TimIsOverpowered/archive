generator meta_client {
  provider = "prisma-client"
  output   = "../generated/meta"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id          String   @id @unique @db.VarChar(25)
  displayName String   @map("display_name")
  twitch      Json?    @map("twitch")
  youtube     Json?    @map("youtube")
  kick        Json?    @map("kick")
  google      Json?    @map("google")
  databaseUrl String?  @map("database_url")
  settings    Json     @default("{}") @map("settings")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  api_key      String   @unique
  api_key_hash String   @unique
  created_at   DateTime @default(now())

  @@map("admins")
}
