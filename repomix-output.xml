<file path="prisma/schema.prisma">
generator streamer_client {
  provider = "prisma-client"
  output   = "../generated/streamer"
}

datasource db {
  provider = "postgresql"
}

model Vod {
  id            Int         @id(map: "vods_new_pkey") @default(autoincrement())
  vod_id        String
  platform      String
  title         String?
  duration      Int         @default(0)
  stream_id     String?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  is_live       Boolean     @default(false)
  started_at    DateTime?
  chapters      Chapter[]
  emotes        Emote?
  games         Game[]
  vod_uploads   VodUpload[]

  @@unique([platform, vod_id])
  @@index([platform], map: "vods_new_platform_idx")
  @@map("vods")
}

model VodUpload {
  vod_id        Int
  upload_id     String       @id
  type          String?
  duration      Int          @default(0)
  part          Int          @default(0)
  status        UploadStatus @default(PENDING)
  thumbnail_url String?
  created_at    DateTime     @default(now())
  vod           Vod          @relation(fields: [vod_id], references: [id], onDelete: Cascade)

  @@index([vod_id])
  @@index([status])
  @@index([type])
  @@index([vod_id, type, part])
  @@map("vod_uploads")
}

model Emote {
  id              Int    @id(map: "emotes_new_pkey") @default(autoincrement())
  vod_id          Int    @unique(map: "emotes_new_vod_id_key")
  ffz_emotes      Json?
  bttv_emotes     Json?
  seventv_emotes Json?
  vod             Vod    @relation(fields: [vod_id], references: [id], onDelete: Cascade, map: "emotes_new_vod_id_fkey")

  @@map("emotes")
}

model Game {
  id             Int      @id(map: "games_new_pkey") @default(autoincrement())
  vod_id         Int
  start_time     Int?
  end_time       Int?
  video_provider String?
  video_id       String?
  thumbnail_url  String?
  game_id        String?
  game_name      String?
  title          String?
  chapter_image  String?
  vod            Vod      @relation(fields: [vod_id], references: [id], onDelete: Cascade, map: "games_new_vod_id_fkey")

  @@index([game_name], map: "games_new_game_name_idx")
  @@index([vod_id, start_time], map: "games_new_vod_id_start_time_idx")
  @@map("games")
}

model Chapter {
  id       Int     @id @default(autoincrement())
  vod_id   Int
  game_id  String?
  name     String?
  image    String?
  duration String?
  start    Int     @default(0)
  end      Int?
  vod      Vod     @relation(fields: [vod_id], references: [id], onDelete: Cascade)

  @@unique([vod_id, start])
  @@index([vod_id, start])
  @@map("chapters")
}

model ChatMessage {
  id                     String    @id(map: "chat_messages_pkey") @db.Uuid
  vod_id                 Int
  display_name           String?
  content_offset_seconds Decimal   @db.Decimal
  user_color             String?
  createdAt              DateTime @map("created_at") @db.Timestamptz(6)
  message                Json?
  user_badges            Json?

