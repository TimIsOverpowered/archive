{
  "name": "archive",
  "description": "",
  "version": "0.0.0",
  "homepage": "",
  "private": true,
  "type": "module",
  "main": "src",
  "keywords": [
    "feathers"
  ],
  "author": {
    "name": "TimIsOverpowered"
  },
  "contributors": [],
  "bugs": {},
  "directories": {
    "lib": "src",
    "test": "test/",
    "config": "config/"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "test": "npm run lint && npm run mocha",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "build": "tsc",
    "dev": "set NODE_ENV=development&& tsx watch src/index.ts",
    "start": "node dist/index.js",
    "api": "tsx src/index.ts",
    "workers": "tsx src/workers/index.ts",
    "auth:youtube": "tsx scripts/auth-youtube.ts",
    "streamer:migrate": "tsx scripts/migrate-streamer.ts",
    "tenant:create": "tsx scripts/create-tenant.ts",
    "tenant:import": "tsx scripts/import-tenant.ts",
    "admin:create": "tsx scripts/create-admin.ts",
    "admin:reset": "tsx scripts/reset-admin-key.ts",
    "prisma:meta:generate": "npx prisma generate --schema=./prisma/meta/schema.prisma",
    "start:pm2": "pm2 start ecosystem.config.js --env production && pm2 save",
    "stop:pm2": "pm2 stop all && pm2 delete all",
    "restart:pm2": "pm2 restart all",
    "logs:pm2": "pm2 logs --lines 100 --raw"
  },
  "standard": {
    "env": [
      "mocha"
    ],
    "ignore": []
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.73.0",
    "commander": "^14.0.3",
    "cycletls": "^2.0.5",
    "dayjs": "^1.11.20",
    "fastify": "^5.8.4",
    "fastify-metrics": "^13.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^171.4.0",
    "hls-parser": "^0.16.1",
    "ioredis": "^5.10.1",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.40.0",
    "puppeteer-extra-plugin-click-and-wait": "^2.3.3",
    "puppeteer-real-browser": "^1.4.4",
    "qs": "^6.15.0",
    "rate-limiter-flexible": "^10.0.1",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/dotenv": "^8.2.3",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^2.6.13",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "dotenv": "^17.4.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "open": "^11.0.0",
    "pm2": "^6.0.14",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
