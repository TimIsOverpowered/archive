{
  "name": "archive",
  "description": "",
  "version": "0.0.0",
  "homepage": "",
  "private": true,
  "type": "module",
  "main": "src",
  "author": {
    "name": "TimIsOverpowered"
  },
  "contributors": [],
  "bugs": {},
  "directories": {
    "tests": "tests/"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "tests": "node --test --import tsx --test-timeout 10000 --test-concurrency true \"tests/**/*.test.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "fix": "npm run format && npm run lint",
    "format": "prettier --write \"src/**/*.ts\"",
    "build": "tsc",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "start": "node dist/index.js",
    "all": "concurrently --names api,workers \"npm run api\" \"npm run workers\"",
    "api": "cross-env NODE_ENV=development tsx src/index.ts",
    "workers": "cross-env NODE_ENV=development tsx src/workers/index.ts",
    "auth:youtube": "tsx scripts/auth-youtube.ts",
    "auth:twitch": "tsx scripts/auth-twitch.ts",
    "streamer:migrate": "tsx scripts/migrate-streamer.ts",
    "tenant:create": "tsx scripts/create-tenant.ts",
    "tenant:import": "tsx scripts/import-tenant.ts",
    "admin:create": "tsx scripts/create-admin.ts",
    "admin:reset": "tsx scripts/reset-admin-key.ts",
    "start:pm2": "pm2 start ecosystem.config.cjs --env production && pm2 save",
    "stop:pm2": "pm2 stop all && pm2 delete all",
    "restart:pm2": "pm2 restart all",
    "logs:pm2": "pm2 logs --lines 100 --raw"
  },
  "standard": {
    "env": [],
    "ignore": []
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.75.2",
    "commander": "^14.0.3",
    "cycletls": "^2.0.5",
    "dayjs": "^1.11.20",
    "fastify": "^5.8.5",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^171.4.0",
    "hls-parser": "^0.16.1",
    "ioredis": "^5.10.1",
    "ipaddr.js": "^2.3.0",
    "kysely": "^0.28.16",
    "lru-cache": "^11.3.5",
    "p-limit": "^7.3.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rate-limiter-flexible": "^11.0.1",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "open": "^11.0.0",
    "pm2": "^6.0.14",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "zod": "^4.3.6"
  }
}
