# Server Configuration
PORT=3000
NODE_ENV=development

# Redis (BullMQ + Twitch token cache)
REDIS_URL=redis://localhost:6379

# Health Endpoint Protection
HEALTH_TOKEN=<random-secret>

# --------------------------------------------------
# META DATABASE CONFIGURATION (configs + admin auth)
# --------------------------------------------------
META_DATABASE_URL=postgresql://user:pass@localhost:5432/archive

# AES-256-GCM encryption for credentials at rest  
# Generate with: openssl rand -hex 32 (must be exactly 64 hex characters = 32 bytes)
ENCRYPTION_MASTER_KEY=<replace-with-64-char-hex-string>

# JWT signing secret (admin dashboard auth)
JWT_SECRET=generate-random-secret-for-jwt-signing

# --------------------------------------------------
# KICK INTEGRATION (optional — only if any streamer uses Kick)
# --------------------------------------------------
KICK_PUPPETEER_MEMORY_LIMIT_MB=512
