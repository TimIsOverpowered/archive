# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3030
HOST=0.0.0.0
LOG_LEVEL=info

# Stats cache TTL in seconds (API only)
STATS_CACHE_TTL=60

# ============================================
# REDIS (BullMQ + Rate Limiting + Cache)
# ============================================
REDIS_URL=redis://localhost:6379

# Compression algorithm for cached data
# Options: brotli (recommended, 85-88% compression) | gzip (80-82%) | none
REDIS_COMPRESSION=brotli

# Compression level: 1-11 for brotli, 1-9 for gzip
# Level 6 recommended (balanced speed/compression, ~15ms overhead per request)
REDIS_COMPRESSION_LEVEL=6

# Enable Redis cache logger (debugging)
ENABLE_REDIS_CACHE_LOGGER=false

# ============================================
# HEALTH ENDPOINT PROTECTION
# ============================================
HEALTH_TOKEN=<generate-random-secret>

# ============================================
# META DATABASE (Configs + Admin Auth)
# ============================================
META_DATABASE_URL= postgresql://<user>:***@<host>:5432/<db>

# ============================================
# PGBOUNCER (Required — Connection Pooler)
# ============================================
# Install: apt install pgbouncer OR docker run -d --name pgbouncer
# Configure: /etc/pgbouncer/pgbouncer.ini and /etc/pgbouncer/userlist.txt
# auth_type = trust (localhost only), pool_mode = transaction
# Format: postgresql://<user>:<pass>@localhost:6432/<db>
PGBOUNCER_URL=postgresql://<user>:***@localhost:6432

# AES-256-GCM encryption key (must be exactly 64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 16
ENCRYPTION_MASTER_KEY=<replace-with-64-char-hex-string>

# ============================================
# CORS CONFIGURATION
# ============================================
# API domain (for CORS and server URLs)
API_DOMAIN=<your_api_domain>

# Admin dashboard origin: allows *.domain
ADMIN_DASHBOARD_DOMAIN=<your_admin_dashboard_domain>

# ============================================
# RATE LIMITING (requests per minute)
# ============================================
RATE_LIMIT_VODS=60
RATE_LIMIT_CHAT=30
RATE_LIMIT_ADMIN_GET=60
RATE_LIMIT_ADMIN_AUTH=20
RATE_LIMIT_BLOCK_DURATION=60

# ============================================
# FLARESOLVERR INTEGRATION
# ============================================
# FlareSolverr API endpoint (must be running externally via Docker or standalone)
# Docker: docker run -d --name flaresolverr -p 8191:8191 -e LOG_LEVEL=info ghcr.io/flaresolverr/flaresolverr:latest
FLARESOLVERR_BASE_URL=http://localhost:8191
FLARESOLVERR_TIMEOUT_MS=300000         # Max wait for challenge resolution (5 minutes)
FLARESOLVERR_SESSION_TTL=3600          # Session cookie persistence in seconds (1 hour)
FLARESOLVERR_CONCURRENCY=3             # Max concurrent FlareSolverr requests

# ============================================
# WORKER INFRASTRUCTURE
# ============================================

# Enable/disable global Discord alerts (single flag for all tenants)
DISCORD_ALERTS_ENABLED=true

# Global Discord Webhook URL for job status notifications (in_progress/failure/success)
# This is the only webhook configured - no per-tenant webhooks supported
DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/<webhook-id>/<token>

# YouTube OAuth Client Credentials
YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# Clears Worker Queues on startup
CLEAR_QUEUES_ON_STARTUP=TRUE

# Worker concurrency limits
VOD_STANDARD_CONCURRENCY=1
YOUTUBE_UPLOAD_CONCURRENCY=1
CHAT_DOWNLOAD_CONCURRENCY=1
MONITOR_CONCURRENCY=10