# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3030
NODE_ENV=development
HOST=0.0.0.0
LOG_LEVEL=info

# ============================================
# REDIS (BullMQ + Rate Limiting + Cache)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# HEALTH ENDPOINT PROTECTION
# ============================================
HEALTH_TOKEN=<generate-random-secret>

# ============================================
# META DATABASE (Configs + Admin Auth)
# ============================================
META_DATABASE_URL= postgresql://<user>:***@<host>:5432/<db>

# AES-256-GCM encryption key (must be exactly 64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 16
ENCRYPTION_MASTER_KEY=<replace-with-64-char-hex-string>

# ============================================
# CORS CONFIGURATION
# ============================================
# API domain (for CORS and server URLs)
API_DOMAIN=archive.overpowered.tv

# Admin dashboard origin: allows *.overpowered.tv
ADMIN_DASHBOARD_DOMAIN=overpowered.tv

# ============================================
# RATE LIMITING (requests per minute)
# ============================================
RATE_LIMIT_VODS=60
RATE_LIMIT_CHAT=30
RATE_LIMIT_ADMIN_GET=60
RATE_LIMIT_ADMIN_WRITE=20
RATE_LIMIT_BLOCK_DURATION=60

# ============================================
# KICK INTEGRATION (Optional)
# ============================================
KICK_PUPPETEER_MEMORY_LIMIT_MB=512

# ============================================
# REDIS CACHE CONTROL
# ============================================
DISABLE_REDIS_CACHE=false
ENABLE_REDIS_CACHE_LOGGER=false

# ============================================
# REDIS CHAT COMPRESSION & CACHE CONFIGURATION
# ============================================
# Compression algorithm for chat logs in Redis
# Options: brotli (recommended, 85-88% compression) | gzip (80-82%) | none
REDIS_CHAT_COMPRESSION=brotli

# Compression level: 1-11 for brotli, 1-9 for gzip
# Level 6 recommended (balanced speed/compression, ~15ms overhead per request)
REDIS_COMPRESSION_LEVEL=6

# Chat cache TTLs in seconds (3 days - optimized for compression savings)
CHAT_CURSOR_TTL=259200           # 3 days - cursor-based pagination cache
CHAT_OFFSET_TTL=259200           # 3 days - bucket/offset cache
CHAT_BUCKET_SIZE_TTL=2592000     # 30 days - bucket size per VOD (effectively permanent)

# Chat page size (fixed, not configurable via query params)
CHAT_PAGE_SIZE=200

# ============================================
# WORKER INFRASTRUCTURE
# ============================================

# Enable/disable global Discord alerts (single flag for all tenants)
DISCORD_ALERTS_ENABLED=true

# Global Discord Webhook URL for job status notifications (in_progress/failure/success)
# This is the only webhook configured - no per-tenant webhooks supported
DISCORD_ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/<webhook-id>/<token>

# YouTube OAuth Client Credentials
YOUTUBE_CLIENT_ID=your-youtube-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

